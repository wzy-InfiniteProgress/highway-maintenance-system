# =====================================================
# 环境变量示例文件
# =====================================================
#
# 使用说明：
# 1. 复制本文件为 .env.local
# 2. 填写实际的值
# 3. 不要将 .env.local 提交到 Git！
#
# =====================================================

# =====================================================
# 数据库配置
# =====================================================

# SQLite (本地开发)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Supabase 生产环境)
# DATABASE_URL="postgresql://[user]:[password]@[host]:5432/[dbname]"

# =====================================================
# JWT 配置
# =====================================================

# JWT 密钥 (生产环境请使用 64 字符以上的随机字符串)
# 生成命令: openssl rand -hex 64
JWT_SECRET="请替换为您的 64 字符随机密钥"

# Token 过期时间
JWT_EXPIRES_IN="7d"

# =====================================================
# 应用配置
# =====================================================

# 应用名称
NEXT_PUBLIC_APP_NAME="高速公路机电维护管理系统"

# 应用 URL (生产环境请填写实际域名)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =====================================================
# 生产环境
# =====================================================

# 设置为 production 启用生产模式
# NODE_ENV="production"
